si bateria > 50 entonces
    mover norte 100;
    activar_camara;
    tomar_foto;
fino;

destino = "Nueva York";
velocidad = 3.5;
sensor_distancia escanear;

mientras bateria > 10 hacer
    patrullar;
fin;

regresar_base;
aterrizar;
